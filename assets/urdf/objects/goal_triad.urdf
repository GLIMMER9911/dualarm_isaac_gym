<?xml version="1.0"?>
<robot name="goal">
  <link name="triad">
    <visual name="x_axis">
      <origin rpy="0 1.5707 0" xyz="0.15 0 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.3"/>
      </geometry>
      <material name="red"/>
    </visual>
    <visual name="y_axis">
      <origin rpy="1.5707 0 0" xyz="0 0.15 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.3"/>
      </geometry>
      <material name="green"/>
    </visual>
    <visual name="z_axis">
      <origin rpy="0 0 0" xyz="0 0 0.15"/>
      <geometry>
        <cylinder radius="0.01" length="0.3"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <!-- materials, only for visuals -->
  <material name="red">
    <color rgba="1.0 0.0 0.0 1.0"/>
  </material>
  <material name="green">
    <color rgba="0.0 1.0 0.0 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.0 0.0 1.0 1.0"/>
  </material>
</robot>
