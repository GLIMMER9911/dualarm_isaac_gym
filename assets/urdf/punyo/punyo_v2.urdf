<?xml version="1.0"?>
<!--
This is a URDF file for the Punyo robot.
The robot has a torso and two arms. Each arm is covered by six floatie 2.0s and one floatie 1.0,
and the end-effector is a bubble paw. This is intended as
a high-fidelity model of the robot.

The continuous joints are limited by hard mechanical stops
at the limits below. The revolute joint are not mechanically
limited, thus using the manufacturer's limits.
The limits are duplicated from models/robot/gen_punyo_jaco_arm.py,
thus, they should be kept in sync.

The effort limits were changed from those of the original URDF
(from Drake) to match the values provided by the vendor in
the Kinova Actuator Series User Guide.
-->
<robot name="punyo">
  <link name="head">
    <visual name='head_visual'>
      <geometry>
        <mesh filename="meshes/A3_Punyo_Head_8k.obj"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision name='neck_collision'>
      <origin rpy="0 0 0" xyz="-0.03 0 0.49"/>
      <geometry>
        <cylinder length="0.05" radius="0.055"/>
      </geometry>
      <material name="white"/>
    </collision>
    <collision name='head_collision'>
      <origin rpy="0 0 0" xyz="0 0 0.655"/>
      <geometry>
        <sphere radius="0.16"/>
      </geometry>
    </collision>
  </link>
  <joint name="head_torso_link" type="fixed">
    <parent link="torso"/>
    <child link="head"/>
    <axis xyz="0 0 0"/>
    <limit effort="2000" lower="0" upper="0" velocity="1"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>
  <link name="torso">
    <visual name='chest_visual'>
      <geometry>
        <mesh filename="meshes/MA-081-PT-0003_chest_middle.obj"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision name='chest_collision'>
      <geometry>
        <mesh filename="meshes/MA-081-PT-0003_chest_middle.obj"/>
      </geometry>
    </collision>
  </link>
  <link name="j2s7s300_link_base_l">
    <visual>
      <geometry>
        <mesh filename="meshes/base.obj"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="meshes/base.obj"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.965"/>
      <origin rpy="0 0 0" xyz="0 0 0.1255"/>
      <inertia ixx="0.000951270861568" ixy="0" ixz="0" iyy="0.000951270861568" iyz="0" izz="0.000374272"/>
    </inertial>
  </link>
  <joint name="j2s7s300_joint_base_l" type="fixed">
    <parent link="torso"/>
    <child link="j2s7s300_link_base_l"/>
    <axis xyz="0 0 0"/>
    <limit effort="2000" lower="0" upper="0" velocity="1"/>
    <origin rpy="0 0 1.5707963267948966" xyz="0 0.27 0.114"/>
