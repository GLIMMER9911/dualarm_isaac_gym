  <!-- base -->
  <ros2_control name="base_JointHardwareInterface" type="system">
    <hardware>
      <plugin>ethercat_driver/EthercatDriver</plugin>
      <param name="master_id">0</param>
      <param name="control_frequency">1000</param>
    </hardware>
    <joint name="base_joint">
      <!-- <state_interface name="position"/> -->
      <!-- <state_interface name="velocity"/> -->
      <!-- <state_interface name="effort"/> -->
      <!-- <command_interface name="velocity"/> -->
      <!-- <command_interface name="velocity"/> -->
      <!-- <command_interface name="reset_fault"/> -->
      <ec_module name="SENSO">
        <plugin>ethercat_generic_plugins/EcCiA402Drive</plugin>
        <param name="alias">0</param>
        <param name="position">0</param>
        <param name="mode_of_operation">-109</param>
        <param name="slave_config">/home/docker/workspace/install/dualarm_description/share/dualarm_description/robots/base_motor/config/senso_joint_config.yaml</param>
      </ec_module>
    </joint>
    <joint name="base_joint">
      <gazebo>
        <hardwareInterface>EffortJointInterface</hardwareInterface>
        <provideFeedback>true</provideFeedback>
      </gazebo>
      <!-- Command Interfaces -->
      <command_interface name="effort"/>
      <!-- State Interfaces -->
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="effort">
        <param name="initial_value">0.0</param>
      </state_interface>
    </joint>
  </ros2_control>
</robot>
